{
  "name": "invoice-processor",
  "private": true,
  "packageManager": "pnpm@10.21.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @invoice-processor/db drizzle-kit generate",
    "db:migrate": "pnpm --filter @invoice-processor/api db:migrate"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "dotenv-cli": "^8.0.0",
    "drizzle-kit": "^0.31.4",
    "turbo": "^2.5.6",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
