{
  "name": "@invoice-processor/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "dotenv -e ../../.env -- node --watch --import tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/apps/api/src/index.js",
    "migrate": "node dist/apps/api/src/db/migrate.js",
    "start:prod": "node dist/apps/api/src/db/migrate.js && node dist/apps/api/src/index.js",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:migrate": "dotenv -e ../../.env -- node --import tsx src/db/migrate.ts"
  },
  "dependencies": {
    "@ai-sdk/openai": "^2.0.31",
    "@hono/node-server": "^1.19.0",
    "@hono/zod-validator": "^0.7.2",
    "@invoice-processor/db": "workspace:*",
    "@invoice-processor/types": "workspace:*",
    "@napi-rs/canvas": "^0.1.77",
    "ai": "^5.0.31",
    "better-sqlite3": "^12.2.0",
    "drizzle-orm": "^0.44.5",
    "dotenv": "^17.2.2",
    "hono": "^4.9.6",
    "mime-types": "^3.0.1",
    "pdfjs-dist": "^5.4.149",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/mime-types": "^3.0.1",
    "tsx": "^4.20.5"
  }
}
